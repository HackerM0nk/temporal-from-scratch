{
  "name": "temporal-version",
  "version": "1.0.0",
  "description": "Subscription workflow implemented with Temporal TypeScript SDK",
  "scripts": {
    "build": "tsc",
    "worker": "ts-node src/worker.ts",
    "api": "ts-node src/api.ts",
    "cli": "ts-node src/cli.ts",
    "start:worker": "TEMPORAL_ADDRESS=localhost:7233 ts-node src/worker.ts",
    "start:api": "TEMPORAL_ADDRESS=localhost:7233 ts-node src/api.ts"
  },
  "dependencies": {
    "@temporalio/activity": "^1.9.0",
    "@temporalio/client": "^1.9.0",
    "@temporalio/worker": "^1.9.0",
    "@temporalio/workflow": "^1.9.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
